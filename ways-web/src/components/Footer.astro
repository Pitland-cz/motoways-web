---
import type { T } from '../i18n';

interface Props {
  tr: T;
}

const { tr } = Astro.props;
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-inner">
      <!-- Brand v3.0 monogram -->
      <div class="footer-brand">
        <img src="/assets/logo/motoways-monogram-dark.svg" alt="Motoways" width="32" height="32" />
        <span class="footer-brand-name">Motoways</span>
      </div>

      <div class="footer-links">
        <a href={tr.footer.privacyHref} class="footer-link">{tr.footer.privacy}</a>
        <a href={tr.footer.contactHref} class="footer-link">{tr.footer.contact}</a>
      </div>
    </div>

    <p class="footer-legal">{tr.footer.legal}</p>
  </div>
</footer>

<style>
  .footer {
    background: var(--c-surface-2, #2a2a28);
    border-top: 1px solid var(--c-border);
    padding: 2.5rem 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .footer-brand-name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--c-white);
    letter-spacing: -0.01em;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-link {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .footer-link:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .footer-legal {
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
  }
</style>
